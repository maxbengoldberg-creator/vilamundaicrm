# ==========================================================
#  Vila Mundaí CRM — variáveis de ambiente
#  Copie este arquivo para ".env" e preencha os valores.
#  No Railway, cole cada par em Settings > Variables.
# ==========================================================

# Porta (o Railway injeta automaticamente; deixe assim)
PORT=3000

# Chave que protege a SUA API (invente uma string longa e secreta).
# É exigida no header "x-api-key" nas rotas administrativas.
APP_API_KEY=troque-por-uma-chave-secreta-bem-longa

# ----- Banco de dados (Railway injeta DATABASE_URL automaticamente
#       quando você adiciona o plugin PostgreSQL) -----
DATABASE_URL=postgresql://usuario:senha@host:5432/railway

# ----- Anthropic (Claude) -----
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxx
# Modelo do agente. Opus = mais inteligente; Sonnet = mais barato/rápido.
CLAUDE_MODEL=claude-opus-4-8
CLAUDE_MAX_TOKENS=1024

# ----- Z-API (WhatsApp) -----
# Pegue em https://app.z-api.io (Instância > parâmetros)
ZAPI_INSTANCE_ID=sua-instancia
ZAPI_TOKEN=seu-token-da-instancia
# "Client-Token" da conta (aba Segurança da Z-API). Obrigatório nas chamadas.
ZAPI_CLIENT_TOKEN=seu-client-token-da-conta

# ----- Hospedin PMS -----
# Base da API conforme a doc: https://pms.hospedin.com/api-docs
HOSPEDIN_BASE_URL=https://pms.hospedin.com/api/v1
# Credenciais para autenticar e obter o token (ver aba "authentication" da doc).
HOSPEDIN_EMAIL=seu-email@hospedin
HOSPEDIN_PASSWORD=sua-senha
# Se a sua conta usa API key fixa em vez de login, preencha aqui e deixe os dois acima vazios:
HOSPEDIN_API_TOKEN=

# Nome da hospedagem (usado nas mensagens do agente)
PROPERTY_NAME=Vila Mundaí
